{
  "manifest_version": 3,
  "name": "PhishGuard - Phishing Prevention",
  "short_name": "PhishGuard",
  "version": "1.0.0",
  "description": "Real-time phishing detection and prevention for Chrome and Edge. Analyzes URLs, certificates, and page content to keep you safe.",
  "author": "PhishGuard Security",

  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "PhishGuard - Click to see security status"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start"
    }
  ],

  "permissions": [
    "activeTab",
    "tabs",
    "webNavigation",
    "webRequest",
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequest"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": ["warning/warning.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "options_page": "dashboard/dashboard.html",

  "commands": {
    "toggle-protection": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Toggle PhishGuard protection"
    },
    "open-dashboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Open security dashboard"
    }
  }
}
