{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "phishguard-backend",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/safebrowsing",
      "dest": "/api/safebrowsing.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/phishtank",
      "dest": "/api/phishtank.js",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/whois",
      "dest": "/api/whois.js",
      "methods": ["GET", "OPTIONS"]
    },
    {
      "src": "/api/report",
      "dest": "/api/report.js",
      "methods": ["POST", "OPTIONS"]
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "no-referrer" }
      ]
    }
  ]
}
